---
interface Props {
  as?: 'article' | 'li' | 'div';
  interactive?: boolean;
  class?: string;
}

const { as: Tag = 'div', interactive = false, class: className = '' } = Astro.props;
const cls = `card ${interactive ? 'is-interactive' : ''} ${className}`.trim();
---

<Tag class={cls}>
  <slot />
</Tag>

<style>
  .card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
  }
  :global(:root:not(.dark)) .card {
    background: rgba(0, 0, 0, 0.02);
  }
  .card.is-interactive {
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }
  .card.is-interactive:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
</style>
