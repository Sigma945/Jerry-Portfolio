---
import type { TKey } from '../i18n';

interface Props {
  i18nKey?: TKey;
}

const { i18nKey } = Astro.props;
---

<h1 class="page-title" data-i18n={i18nKey}>
  <slot />
</h1>

<style>
  .page-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 32px;
  }
</style>
