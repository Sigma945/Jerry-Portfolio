---
import { translations } from '../i18n';
import { path } from '../routes';

const twFlagPath = path('/flags/tw.svg');
const usFlagPath = path('/flags/us.svg');
---

<button
  id="lang-toggle"
  type="button"
  aria-label="切換語言 / Toggle language"
  class="lang-toggle"
><img class="lang-flag" src={twFlagPath} alt="" aria-hidden="true" /> Ch</button>

<script is:inline define:vars={{ translations, twFlagPath, usFlagPath }}>
  (() => {
    const btn = document.getElementById('lang-toggle');
    if (!btn) return;

    const getLabel = (lang) => {
      if (lang === 'en') {
        return `<img class="lang-flag" src="${usFlagPath}" alt="" aria-hidden="true" /> En`;
      }
      return `<img class="lang-flag" src="${twFlagPath}" alt="" aria-hidden="true" /> Ch`;
    };

    const apply = (lang) => {
      document.documentElement.lang = lang === 'en' ? 'en' : 'zh-Hant';
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const k = el.getAttribute('data-i18n');
        if (k && translations[lang] && translations[lang][k]) {
          el.textContent = translations[lang][k];
        }
      });
      btn.innerHTML = getLabel(lang);
    };

    const initial = localStorage.getItem('lang') === 'en' ? 'en' : 'zh';
    apply(initial);

    btn.addEventListener('click', () => {
      const next = (localStorage.getItem('lang') === 'en' ? 'zh' : 'en');
      localStorage.setItem('lang', next);
      apply(next);
    });
  })();
</script>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    min-width: 2.25rem;
    height: 1.5rem;
    padding: 0 0.5rem;
    border: 1px solid var(--border-strong);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--fg);
    font: inherit;
    font-size: 0.75rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .lang-toggle:hover {
    background: var(--surface);
  }
  .lang-flag {
    width: 0.75rem;
    height: 0.75rem;
    flex: 0 0 auto;
    border-radius: 2px;
  }
</style>
