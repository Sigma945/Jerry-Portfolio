---
import { site } from '../site';
import { path } from '../routes';
import IconMail from './icons/IconMail.astro';
import IconGithub from './icons/IconGithub.astro';
import IconRss from './icons/IconRss.astro';

const links = [
  { type: 'email' as const, icon: IconMail,   href: `mailto:${site.social.email}`, label: site.social.email },
  { type: 'github' as const, icon: IconGithub, href: site.social.github,            label: 'GitHub' },
  { type: 'rss' as const,   icon: IconRss,   href: path(site.social.rss),         label: 'RSS' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <ul class="footer-links">
      {links.map(({ type, icon: Icon, href, label }) => (
        <li>
          <a href={href} class="footer-link" rel={type === 'github' ? 'me noopener' : undefined}>
            <Icon class="footer-icon" />
            <span>{label}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="copy">© {new Date().getFullYear()} {site.name}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
  }
  .footer-inner {
    padding-block: 32px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
  }
  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .footer-link:hover {
    color: var(--fg);
  }
  .footer-icon {
    font-size: 14px;
    flex: 0 0 auto;
  }
  .copy {
    margin: 0;
    font-size: 13px;
    color: var(--muted-2);
    font-family: var(--font-mono);
  }
</style>
