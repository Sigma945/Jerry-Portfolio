---
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path}`;

const links = [
  { href: url('/'), label: 'Home' },
  { href: url('/about'), label: 'About' },
  { href: url('/projects'), label: 'Projects' },
  { href: url('/blog'), label: 'Blog' },
  { href: url('/experiments'), label: 'Experiments' },
  { href: url('/resume'), label: 'Resume' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href={url('/')} class="brand">Jerry Chen</a>

    <ul class="nav-links desktop">
      {links.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>

    <div class="nav-actions">
      <ThemeToggle />
      <button
        id="nav-menu-btn"
        type="button"
        aria-controls="nav-menu"
        aria-expanded="false"
        aria-label="開啟選單"
        class="menu-btn"
      >
        <svg id="nav-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="nav-icon-close" class="hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18"/>
          <line x1="6" y1="18" x2="18" y2="6"/>
        </svg>
      </button>
    </div>
  </div>

  <ul id="nav-menu" class="nav-links mobile hidden">
    {links.map(({ href, label }) => (
      <li><a href={href}>{label}</a></li>
    ))}
  </ul>
</nav>

<script is:inline>
  (() => {
    const btn = document.getElementById('nav-menu-btn');
    const menu = document.getElementById('nav-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    if (!btn || !menu || !iconOpen || !iconClose) return;
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
    });
  })();
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--nav-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 56rem;
    margin-inline: auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-weight: 700;
    color: var(--fg);
    text-decoration: none;
  }
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s;
  }
  .nav-links a:hover {
    color: var(--fg);
  }
  .nav-links.desktop {
    display: none;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .nav-links.mobile {
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
  }
  .nav-links.mobile li {
    padding-block: 0.25rem;
  }
  .nav-links.mobile a {
    display: block;
    font-size: 0.875rem;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--fg);
    cursor: pointer;
  }
  .menu-btn:hover {
    background: var(--surface);
  }
  .menu-btn svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-links.desktop {
      display: flex;
    }
    .nav-links.mobile,
    .menu-btn {
      display: none;
    }
  }
</style>
