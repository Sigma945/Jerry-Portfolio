---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <article>
    <h1>{post.data.title}</h1>
    <p class="date">{formatDate(post.data.date)}</p>
    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 720px;
  }
  article h1 {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }
  .date {
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--muted-2);
    margin: 16px 0 0;
    letter-spacing: 0.02em;
  }
  .body {
    margin-top: 48px;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.8;
  }
  .body :global(> * + *) {
    margin-top: 24px;
  }
  .body :global(p) {
    margin: 0;
  }

  .body :global(h2),
  .body :global(h3),
  .body :global(h4) {
    color: var(--fg);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    scroll-margin-top: 88px;
  }
  .body :global(h2) {
    font-size: 28px;
    margin: 56px 0 16px;
  }
  .body :global(h3) {
    font-size: 22px;
    margin: 40px 0 12px;
  }
  .body :global(h4) {
    font-size: 18px;
    margin: 32px 0 8px;
  }

  .body :global(a) {
    color: var(--accent);
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }
  .body :global(a):hover {
    opacity: 0.7;
  }

  .body :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }
  .body :global(em) {
    font-style: italic;
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 0;
    padding-left: 1.6em;
  }
  .body :global(ul) {
    list-style: disc;
  }
  .body :global(ol) {
    list-style: decimal;
  }
  .body :global(ul ul) {
    list-style: circle;
  }
  .body :global(ul ul ul) {
    list-style: square;
  }
  .body :global(li + li) {
    margin-top: 8px;
  }
  .body :global(li > ul),
  .body :global(li > ol) {
    margin-top: 8px;
  }
  .body :global(li::marker) {
    color: var(--muted-2);
  }

  .body :global(details) {
    padding: 12px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .body :global(details + details) {
    margin-top: 12px;
  }
  .body :global(summary) {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-weight: 500;
    list-style: none;
  }
  .body :global(summary::-webkit-details-marker) {
    display: none;
  }
  .body :global(summary::before) {
    content: '▸';
    color: var(--muted-2);
    font-size: 12px;
    flex: 0 0 auto;
  }
  .body :global(details[open]) > summary::before {
    content: '▾';
  }
  .body :global(details[open]) > summary {
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .body :global(blockquote) {
    margin: 0;
    padding: 4px 20px;
    border-left: 3px solid var(--border-strong);
    color: var(--muted-2);
    font-style: italic;
  }

  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 2px 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
  }
  .body :global(pre) {
    margin: 0;
    padding: 20px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.6;
  }
  .body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
    color: inherit;
  }

  .body :global(hr) {
    margin: 48px 0;
    border: 0;
    border-top: 1px solid var(--border);
  }

  .body :global(img),
  .body :global(video),
  .body :global(iframe) {
    max-width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
    display: block;
  }
  .body :global(img),
  .body :global(video) {
    height: auto;
  }
  .body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
  }
  .body :global(figure) {
    margin: 0;
  }
  .body :global(figcaption) {
    margin-top: 8px;
    font-size: 13px;
    color: var(--muted-2);
    text-align: center;
  }

  .body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .body :global(th),
  .body :global(td) {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .body :global(tbody tr:last-child td) {
    border-bottom: none;
  }
  .body :global(thead th) {
    background: var(--surface);
    color: var(--muted-2);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
