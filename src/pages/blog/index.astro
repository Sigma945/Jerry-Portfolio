---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Blog — Jerry Chen">
  <h1 class="page-title">Blog / Notes</h1>

  <ul class="posts">
    {posts.map(post => (
      <li class="post">
        <a href={`${base}/blog/${post.id}`}>
          <h2>{post.data.title}</h2>
          <p class="date">{post.data.date.toISOString().slice(0, 10)}</p>
          {post.data.description && <p class="desc">{post.data.description}</p>}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }
  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }
  .post a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .post h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    transition: color 0.15s;
  }
  .post a:hover h2 {
    color: var(--accent);
  }
  .date {
    font-size: 0.875rem;
    color: var(--muted-2);
    margin: 0.25rem 0 0;
  }
  .desc {
    margin-top: 0.5rem;
    color: var(--muted-2);
  }
</style>
