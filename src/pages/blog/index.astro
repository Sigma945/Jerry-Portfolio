---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Blog — Jerry Chen">
  <h1 class="text-3xl font-bold mb-6">Blog / Notes</h1>

  <ul class="space-y-4">
    {posts.map(post => (
      <li class="border-b border-gray-800 pb-4">
        <a href={`${base}/blog/${post.id}`} class="block group">
          <h2 class="text-xl font-semibold group-hover:text-blue-400">{post.data.title}</h2>
          <p class="text-sm text-gray-500 mt-1">
            {post.data.date.toISOString().slice(0, 10)}
          </p>
          {post.data.description && (
            <p class="mt-2 text-gray-400">{post.data.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
