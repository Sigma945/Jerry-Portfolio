---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="Experiments — Jerry Chen">
  <h1 class="page-title" data-i18n="page.experiments">實驗</h1>
  <p class="lead">這裡放一些小實驗：互動元件、動畫、技術 demo。</p>

  <ul class="cards">
    <Card as="li">（待補）</Card>
  </ul>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }
  .lead {
    color: var(--muted-2);
  }
  .cards {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: var(--muted);
  }
</style>
