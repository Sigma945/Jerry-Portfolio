---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';

const projects = await getCollection('projects');
---

<BaseLayout title="Projects — Jerry Chen">
  <h1 class="page-title">Projects</h1>

  <div class="grid">
    {projects.map(project => (
      <Card as="article" interactive>
        <h2>{project.data.title}</h2>
        <p class="desc">{project.data.description}</p>
        {project.data.tech && (
          <ul class="tech">
            {project.data.tech.map(t => <li>{t}</li>)}
          </ul>
        )}
        {project.data.link && (
          <a href={project.data.link} class="link">查看 →</a>
        )}
      </Card>
    ))}
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
  }
  .desc {
    margin-top: 0.5rem;
    color: var(--muted-2);
  }
  .tech {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted-2);
  }
  .tech li {
    background: var(--surface);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
  .link {
    color: var(--accent);
    margin-top: 1rem;
    display: inline-block;
    text-decoration: none;
  }
  .link:hover {
    color: var(--accent-hover);
  }
</style>
