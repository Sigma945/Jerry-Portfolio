---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = await getCollection('projects');
---

<BaseLayout title="Projects — Jerry Chen">
  <h1 class="text-3xl font-bold mb-6">Projects</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map(project => (
      <article class="border border-gray-300 dark:border-gray-700 p-5 rounded-lg hover:border-gray-500 transition">
        <h2 class="text-xl font-semibold">{project.data.title}</h2>
        <p class="mt-2 text-gray-600 dark:text-gray-400">{project.data.description}</p>
        {project.data.tech && (
          <ul class="mt-3 flex flex-wrap gap-2 text-xs text-gray-600 dark:text-gray-400">
            {project.data.tech.map(t => <li class="px-2 py-1 bg-gray-200 dark:bg-gray-800 rounded">{t}</li>)}
          </ul>
        )}
        {project.data.link && (
          <a href={project.data.link} class="text-blue-500 dark:text-blue-400 mt-4 inline-block">查看 →</a>
        )}
      </article>
    ))}
  </div>
</BaseLayout>
