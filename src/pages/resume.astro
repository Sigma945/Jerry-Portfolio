---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Jerry Chen">
  <h1 class="text-3xl font-bold mb-6">Resume</h1>

  <section class="mb-8">
    <h2 class="text-xl font-semibold border-b border-gray-200 dark:border-gray-800 pb-2">Profile</h2>
    <p class="mt-3 text-gray-700 dark:text-gray-300">Jerry Chen ・ Full-stack Developer</p>
  </section>

  <section class="mb-8">
    <h2 class="text-xl font-semibold border-b border-gray-200 dark:border-gray-800 pb-2">Experience</h2>
    <ul class="mt-3 space-y-3 text-gray-700 dark:text-gray-300">
      <li>（待補）</li>
    </ul>
  </section>

  <section class="mb-8">
    <h2 class="text-xl font-semibold border-b border-gray-200 dark:border-gray-800 pb-2">Skills</h2>
    <ul class="mt-3 flex flex-wrap gap-2 text-sm">
      <li class="px-2 py-1 bg-gray-200 dark:bg-gray-800 rounded">Astro</li>
      <li class="px-2 py-1 bg-gray-200 dark:bg-gray-800 rounded">Tailwind</li>
    </ul>
  </section>
</BaseLayout>
