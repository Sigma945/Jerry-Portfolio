---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Jerry Chen">
  <h1 class="page-title" data-i18n="page.resume">履歷</h1>

  <section>
    <h2>Profile</h2>
    <p>Jerry Chen ・ Full-stack Developer</p>
  </section>

  <section>
    <h2>Experience</h2>
    <ul class="list">
      <li>（待補）</li>
    </ul>
  </section>

  <section>
    <h2>Skills</h2>
    <ul class="chips">
      <li>Astro</li>
      <li>Tailwind</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }
  section {
    margin-bottom: 2rem;
  }
  section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin: 0;
  }
  section p {
    margin-top: 0.75rem;
    color: var(--muted);
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .chips {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.875rem;
  }
  .chips li {
    background: var(--surface);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
