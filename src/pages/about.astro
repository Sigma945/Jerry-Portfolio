---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Jerry Chen">
  <h1 class="page-title">About</h1>
  <div class="prose">
    <p>嗨，我是 Jerry，一名喜歡打造完整產品的工程師。</p>
    <p>我關注前端體驗、後端架構、以及如何用簡潔的方式把事情做完。</p>
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }
  .prose {
    color: var(--muted);
    line-height: 1.7;
  }
  .prose p + p {
    margin-top: 1rem;
  }
</style>
