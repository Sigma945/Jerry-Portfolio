---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import { experience } from '../data/experience';
---

<BaseLayout title="About">
  <PageTitle i18nKey="page.about">關於</PageTitle>
  <div class="prose">
    <p>嗨，我是 Jerry Chen，一名網頁全端工程師。</p>
    <p>我關注前端體驗、後端架構、以及如何用簡潔的方式把事情做完。</p>
    <p>目前主要使用 Vue3、Tailwind、TypeScript 等前端技術建構網站，也熟悉.net、C#、EF Core與資料庫工具。</p>
    <p>過去的工作經歷涵蓋網站開發、前後端整合，與小型專案的規劃與實作。</p>
    <p>開發過程中也積極使用各式AI作為輔助開發，提升專案執行效率</p>
  </div>

  <hr class="section-divider" />
  <h2 class="section-title">實作專案技術</h2>
  
  <div class="table-wrap">
    <table class="tech-table">
      <thead>
        <tr>
          <th>專案</th>
          <th>前端</th>
          <th>後端</th>
          <th>資料庫</th>
        </tr>
      </thead>
      <tbody>
        {experience.map(p => (
          <tr>
            <td>{p.name}</td>
            <td>{p.frontend}</td>
            <td>{p.backend}</td>
            <td>{p.db}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>

<style>
  .prose {
    max-width: 720px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.8;
  }
  .prose p {
    margin: 0;
  }
  .prose p + p {
    margin-top: 16px;
  }
  .section-divider {
    margin: 64px 0 24px;
    border: 0;
    border-top: 1px solid var(--border);
  }
  .section-title {
    margin: 0 0 24px;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.02);
  }
  :global(:root:not(.dark)) .table-wrap {
    background: rgba(0, 0, 0, 0.02);
  }
  .tech-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .tech-table th,
  .tech-table td {
    padding: 14px 20px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .tech-table thead th {
    color: var(--muted-2);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .tech-table tbody tr:last-child td {
    border-bottom: none;
  }
  .tech-table tbody td {
    color: var(--muted);
  }
  .tech-table tbody tr {
    transition: background 0.2s ease;
  }
  .tech-table tbody tr:hover {
    background: var(--surface);
  }
  .tech-table tbody tr:hover td:first-child {
    color: var(--fg);
  }
</style>
