---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { routes } from '../routes';
import { site } from '../site';
---

<BaseLayout>
  <section class="hero">
    <h1>{site.name}</h1>
    <p class="tagline">{site.tagline}</p>
    <p class="bio">
      我是一名專案網站的全端開發者，喜歡用程式碼把想法變成可運作的成品。
    </p>
    <div class="actions">
      <Button href={routes.projects.href} variant="primary">
        <span data-i18n="home.viewProjects">查看作品</span>
      </Button>
      <Button href={routes.about.href} variant="ghost">
        <span data-i18n="nav.about">關於</span>
      </Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 2.5rem;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
  }
  .tagline {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--muted);
  }
  .bio {
    margin-top: 1.5rem;
    max-width: 36rem;
    color: var(--muted-2);
  }
  .actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
