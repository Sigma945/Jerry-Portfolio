---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Jerry Chen — Home">
  <section class="hero">
    <h1>Jerry Chen</h1>
    <p class="tagline">Full-stack Developer</p>
    <p class="bio">
      我是一個專注於專案網站的開發者，喜歡用程式碼把想法變成可運作的成品。
    </p>
    <div class="actions">
      <Button href={`${base}/projects`} variant="primary">
        <span data-i18n="home.viewProjects">查看作品</span>
      </Button>
      <Button href={`${base}/resume`} variant="ghost">
        <span data-i18n="home.viewResume">我的履歷</span>
      </Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 2.5rem;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
  }
  .tagline {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--muted);
  }
  .bio {
    margin-top: 1.5rem;
    max-width: 36rem;
    color: var(--muted-2);
  }
  .actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
