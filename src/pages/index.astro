---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { routes } from '../routes';
import { site } from '../site';
---

<BaseLayout>
  <section class="hero">
    <h1>{site.name}</h1>
    <p class="tagline">{site.tagline}</p>
    <p class="bio">
      我是一名專案網站的全端開發者，喜歡用程式碼把想法變成可運作的成品。
    </p>
    <div class="actions">
      <Button href={routes.projects.href} variant="primary">
        <span data-i18n="home.viewProjects">查看作品</span>
      </Button>
      <Button href={routes.about.href} variant="ghost">
        <span data-i18n="nav.about">關於</span>
      </Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 48px;
  }
  .hero h1 {
    font-size: 72px;
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0;
  }
  .tagline {
    margin-top: 24px;
    font-size: 20px;
    color: var(--muted);
    letter-spacing: -0.01em;
  }
  .bio {
    margin-top: 24px;
    max-width: 560px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted-2);
  }
  .actions {
    margin-top: 40px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 64px;
    }
    .hero h1 {
      font-size: 48px;
    }
  }
</style>
